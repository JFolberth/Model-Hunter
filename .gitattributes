# Auto-detect text files and normalize line endings
* text=auto

# Force LF for scripts and config (consistent across Mac/Windows)
*.ps1 text eol=lf
*.tf text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
