{
  "name": "Model Hunter",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:1": {
      "version": "7.4"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers-extra/features/tflint:1": {}
  },
  "postCreateCommand": "pwsh -Command \"Set-PSRepository -Name PSGallery -InstallationPolicy Trusted; Install-Module -Name Az.Accounts, Az.ResourceGraph, Az.CostManagement, Az.Storage, Az.Billing, Pester -Force -Scope CurrentUser -AcceptLicense\" && curl -s https://raw.githubusercontent.com/aquasecurity/tfsec/master/scripts/install_linux.sh | bash",
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "ms-azuretools.vscode-azureterraform",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-vscode.powershell",
        "github.copilot",
        "github.copilot-chat",
        "mechatroner.rainbow-csv",
        "daiyy.quick-html-previewer",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "GitHub.vscode-codeql",
        "aquasecurityofficial.trivy-vulnerability-scanner"
      ],
      "settings": {
        "terraform.languageServer.enable": true,
        "powershell.powerShellDefaultVersion": "PowerShell (7.4)",
        "editor.formatOnSave": true,
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.terraform",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "remoteEnv": {
    "TF_PLUGIN_CACHE_DIR": "/home/vscode/.terraform.d/plugin-cache"
  },
  "postStartCommand": "mkdir -p $TF_PLUGIN_CACHE_DIR"
}
